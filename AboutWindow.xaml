<Window x:Class="RdlcRendererWpf.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About RDLC Report Tester"
        Height="300"
        Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="30" VerticalAlignment="Center">
        <TextBlock Text="RDLC Report Tester" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10"/>
        
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Version 2.01" FontSize="13" Foreground="#374151"/>
            <TextBlock Text="2026.04.02" FontSize="13" Foreground="#374151" Margin="0,3,0,0"/>
            <TextBlock Text="MIT License" FontSize="13" Foreground="#374151" Margin="0,3,0,0"/>
        </StackPanel>

        <TextBlock Text="A development tool for testing RDLC reports with XML DataSource from Business Central" 
                   FontSize="12" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <TextBlock Text="Contact:" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
        <TextBlock Text="StackCollaider@gmail.com" FontSize="12" Foreground="#3B82F6" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <Button Content="Close" Width="100" Height="32" Click="CloseButton_Click" 
                Background="#2563EB" Foreground="White" BorderThickness="0" HorizontalAlignment="Right"/>
    </StackPanel>
</Window>
